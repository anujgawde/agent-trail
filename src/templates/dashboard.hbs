<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>agent-trail</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --orange:     #E8623A;
  --orange-dk:  #C9502D;
  --orange-lt:  #FEF3EE;
  --green:      #16A34A;
  --green-lt:   #F0FDF4;
  --red:        #DC2626;
  --red-lt:     #FEF2F2;
  --blue:       #2563EB;
  --sidebar-w:  228px;
  --gray-50:    #F9FAFB;
  --gray-100:   #F3F4F6;
  --gray-150:   #EDEFF2;
  --gray-200:   #E5E7EB;
  --gray-300:   #D1D5DB;
  --gray-400:   #9CA3AF;
  --gray-500:   #6B7280;
  --gray-600:   #4B5563;
  --gray-700:   #374151;
  --gray-800:   #1F2937;
  --gray-900:   #111827;
  --radius:     10px;
  --shadow-sm:  0 1px 3px rgba(0,0,0,0.05), 0 1px 2px rgba(0,0,0,0.04);
}

html, body { height: 100%; }

body {
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--gray-50);
  color: var(--gray-900);
  font-size: 14px;
  line-height: 1.5;
  display: flex;
}

/* ── Sidebar ── */
.sidebar {
  width: var(--sidebar-w);
  min-height: 100vh;
  background: #fff;
  border-right: 1px solid var(--gray-200);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0; left: 0;
  z-index: 20;
  padding-bottom: 20px;
}

.sidebar-brand {
  padding: 14px 16px 12px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid var(--gray-100);
  margin-bottom: 6px;
}

.brand-logo {
  width: 34px; height: 34px;
  background: var(--orange);
  border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  color: #fff;
  font-weight: 800;
  font-size: 13px;
  letter-spacing: -0.3px;
  flex-shrink: 0;
}

.brand-name {
  font-weight: 700;
  font-size: 14px;
  color: var(--gray-900);
  letter-spacing: -0.2px;
}

.nav-group { padding: 4px 8px 2px; }

.nav-group-label {
  font-size: 10.5px;
  font-weight: 700;
  color: var(--gray-400);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  padding: 8px 8px 5px;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 10px;
  border-radius: 7px;
  cursor: pointer;
  color: var(--gray-600);
  font-size: 13px;
  font-weight: 500;
  transition: background 0.12s, color 0.12s;
  user-select: none;
  text-decoration: none;
  margin-bottom: 1px;
}

.nav-link:hover { background: var(--gray-100); color: var(--gray-900); }

.nav-link.active {
  background: var(--orange-lt);
  color: var(--orange);
  font-weight: 600;
}

.nav-icon {
  width: 15px; height: 15px;
  flex-shrink: 0;
  stroke: currentColor;
  fill: none;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.nav-badge {
  margin-left: auto;
  background: var(--orange);
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.sidebar-footer {
  margin-top: auto;
  padding: 12px 18px 0;
  border-top: 1px solid var(--gray-100);
  font-size: 11px;
  color: var(--gray-400);
  line-height: 1.6;
}

/* ── Main ── */
.main {
  margin-left: var(--sidebar-w);
  flex: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── Topbar ── */
.topbar {
  background: #fff;
  border-bottom: 1px solid var(--gray-200);
  padding: 0 32px;
  height: 52px;
  display: flex;
  align-items: center;
  gap: 12px;
  position: sticky;
  top: 0;
  z-index: 10;
}

.topbar-title {
  font-weight: 700;
  font-size: 15px;
  color: var(--gray-900);
}

.topbar-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }

.filter-chip {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 5px 10px;
  border: 1px solid var(--gray-200);
  border-radius: 6px;
  font-size: 12px;
  color: var(--gray-600);
  background: #fff;
  cursor: default;
}

.filter-chip svg {
  width: 12px; height: 12px;
  stroke: var(--gray-400);
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.beta-tag {
  font-size: 10px;
  font-weight: 700;
  background: var(--orange);
  color: #fff;
  padding: 3px 7px;
  border-radius: 5px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* ── Sections ── */
.section { display: none; }
.section.active { display: flex; flex-direction: column; flex: 1; }

.page-body { padding: 28px 32px 64px; }

.page-header { margin-bottom: 22px; }
.page-header h1 { font-size: 20px; font-weight: 700; color: var(--gray-900); letter-spacing: -0.3px; }
.page-subtitle { font-size: 13px; color: var(--gray-500); margin-top: 3px; }

/* ── Headline card ── */
.headline-card {
  background: #fff;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  padding: 22px 28px;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 28px;
  box-shadow: var(--shadow-sm);
}

.headline-metric { flex-shrink: 0; }

.headline-val {
  font-size: 46px;
  font-weight: 800;
  color: var(--orange);
  line-height: 1;
  letter-spacing: -2px;
  font-variant-numeric: tabular-nums;
}

.headline-unit {
  font-size: 12px;
  color: var(--gray-400);
  font-weight: 500;
  margin-top: 5px;
}

.headline-sep {
  width: 1px;
  height: 56px;
  background: var(--gray-200);
  flex-shrink: 0;
}

.headline-copy strong {
  display: block;
  font-size: 13.5px;
  font-weight: 700;
  color: var(--gray-800);
  margin-bottom: 4px;
}

.headline-copy p {
  font-size: 12.5px;
  color: var(--gray-500);
  max-width: 360px;
  line-height: 1.65;
}

/* ── Stat cards ── */
.stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  margin-bottom: 20px;
}

.stat-card {
  background: #fff;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  padding: 18px 20px 16px;
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
  cursor: default;
}

.stat-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2.5px;
  background: var(--card-accent, transparent);
  border-radius: 0 0 var(--radius) var(--radius);
  opacity: 0;
  transition: opacity 0.2s;
}

.stat-card:hover::after { opacity: 1; }

.stat-label {
  font-size: 11px;
  font-weight: 700;
  color: var(--gray-400);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  margin-bottom: 8px;
}

.stat-val {
  font-size: 30px;
  font-weight: 800;
  color: var(--gray-900);
  line-height: 1;
  letter-spacing: -1px;
  font-variant-numeric: tabular-nums;
}

.stat-sub {
  font-size: 11.5px;
  color: var(--gray-400);
  margin-top: 5px;
}

/* ── Chart card ── */
.chart-card {
  background: #fff;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  padding: 20px 24px;
  margin-bottom: 20px;
  box-shadow: var(--shadow-sm);
}

.chart-head {
  margin-bottom: 16px;
}

.chart-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--gray-800);
}

.chart-desc {
  font-size: 12px;
  color: var(--gray-400);
  margin-top: 2px;
}

.chart-svg-wrap { overflow: hidden; border-radius: 6px; }

/* ── Sessions section ── */
.section-head {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}

.section-head-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--gray-900);
}

.count-chip {
  font-size: 11.5px;
  font-weight: 600;
  color: var(--gray-500);
  background: var(--gray-100);
  padding: 2px 8px;
  border-radius: 99px;
}

/* ── Table ── */
.table-card {
  background: #fff;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.table-head {
  display: grid;
  grid-template-columns: 155px 1fr 68px 62px 62px 76px 96px 118px;
  gap: 12px;
  padding: 9px 20px;
  background: var(--gray-50);
  border-bottom: 1px solid var(--gray-200);
}

.th {
  font-size: 10.5px;
  font-weight: 700;
  color: var(--gray-400);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.th.r { text-align: right; }

details.srow { border-bottom: 1px solid var(--gray-100); }
details.srow:last-child { border-bottom: none; }
details.srow[open] { border-bottom-color: var(--gray-200); }

summary.srow-sum {
  display: grid;
  grid-template-columns: 155px 1fr 68px 62px 62px 76px 96px 118px;
  gap: 12px;
  padding: 11px 20px;
  cursor: pointer;
  list-style: none;
  user-select: none;
  align-items: center;
  transition: background 0.1s;
}

summary.srow-sum::-webkit-details-marker { display: none; }
summary.srow-sum:hover { background: var(--gray-50); }
details.srow[open] summary.srow-sum { background: var(--orange-lt); }

.c-date  { font-size: 12px; color: var(--gray-500); font-weight: 500; }
.c-proj  { font-size: 13px; font-weight: 600; color: var(--gray-900); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.c-num   { font-size: 12.5px; color: var(--gray-700); text-align: right; font-variant-numeric: tabular-nums; }
.c-cost  { font-size: 12.5px; font-weight: 700; color: var(--gray-900); text-align: right; font-variant-numeric: tabular-nums; }

.bar-wrap { display: flex; align-items: center; }
.bar-bg { flex: 1; height: 4px; background: var(--gray-150); border-radius: 99px; overflow: hidden; }
.bar-fill { height: 100%; background: var(--orange); border-radius: 99px; }

.badge {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 8px;
  border-radius: 6px;
  font-size: 10.5px; font-weight: 700;
  letter-spacing: 0.01em; white-space: nowrap;
}
.badge::before {
  content: '';
  width: 5px; height: 5px;
  border-radius: 50%; background: currentColor; flex-shrink: 0;
}

.b-merged   { background: var(--green-lt); color: var(--green); }
.b-reverted { background: var(--red-lt);   color: var(--red);   }
.b-open     { background: var(--orange-lt); color: var(--orange); }
.b-abandon  { background: var(--gray-100); color: var(--gray-500); }
.b-nopr     { background: var(--gray-100); color: var(--gray-400); }

/* ── Session detail ── */
.srow-detail {
  padding: 16px 20px 18px;
  background: var(--gray-50);
  border-top: 1px solid var(--gray-200);
}

.detail-meta-row {
  display: flex; gap: 28px; flex-wrap: wrap; margin-bottom: 14px;
}

.dmeta { font-size: 12px; color: var(--gray-500); }
.dmeta strong {
  display: block;
  font-size: 10.5px;
  font-weight: 700;
  color: var(--gray-400);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 2px;
}

.commits-label {
  font-size: 11px; font-weight: 700;
  color: var(--gray-500);
  text-transform: uppercase; letter-spacing: 0.06em;
  margin-bottom: 8px;
}

.ctable {
  width: 100%; border-collapse: collapse; font-size: 12px;
  background: #fff; border-radius: 8px; overflow: hidden;
  border: 1px solid var(--gray-200);
}

.ctable th {
  text-align: left; color: var(--gray-400); font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.04em;
  padding: 7px 12px; font-size: 10px;
  background: var(--gray-50); border-bottom: 1px solid var(--gray-200);
}

.ctable td { padding: 8px 12px; border-top: 1px solid var(--gray-100); }
.ctable tr:first-child td { border-top: none; }

.sha-chip {
  font-family: "SF Mono", "Fira Code", "Cascadia Code", ui-monospace, monospace;
  color: var(--blue); font-size: 11px;
  background: #EFF6FF; padding: 2px 6px; border-radius: 4px;
}

.la { color: var(--green); font-weight: 700; }
.ld { color: var(--red);   font-weight: 700; }
.pr-a { color: var(--orange); text-decoration: none; font-weight: 700; }
.pr-a:hover { text-decoration: underline; }

/* ── Empty ── */
.empty-state {
  text-align: center; padding: 56px 24px;
  color: var(--gray-400); font-size: 13px;
}

.empty-icon {
  width: 40px; height: 40px;
  background: var(--gray-100); border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 12px; color: var(--gray-300);
}

/* ── Scroll ── */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--gray-200); border-radius: 3px; }
</style>
</head>
<body>

<!-- ═══ Sidebar ═══ -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-logo">AT</div>
    <span class="brand-name">agent-trail</span>
  </div>

  <div class="nav-group">
    <div class="nav-group-label">Reports</div>
    <a class="nav-link active" data-nav="overview">
      <svg class="nav-icon" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Overview
    </a>
    <a class="nav-link" data-nav="sessions">
      <svg class="nav-icon" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>
      Sessions
    </a>
  </div>

  <div class="nav-group">
    <div class="nav-group-label">Insights</div>
    <a class="nav-link" data-nav="ai">
      <svg class="nav-icon" viewBox="0 0 24 24"><path d="M12 2a5 5 0 015 5v1a5 5 0 01-10 0V7a5 5 0 015-5z"/><path d="M12 14c-5.33 0-8 2.67-8 4v2h16v-2c0-1.33-2.67-4-8-4z"/></svg>
      AI Usage
      <span class="nav-badge">Beta</span>
    </a>
  </div>

  <div class="sidebar-footer">
    Generated<br>{{generatedAt}}
  </div>
</aside>

<!-- ═══ Main ═══ -->
<main class="main">

  <!-- ─── Overview ─── -->
  <div id="sec-overview" class="section active">
    <div class="topbar">
      <span class="topbar-title">Overview</span>
      <div class="topbar-right">
        <div class="filter-chip">
          <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          All sessions
        </div>
      </div>
    </div>
    <div class="page-body">
      <div class="page-header">
        <h1>Overview</h1>
        <p class="page-subtitle">Understand how your Claude Code sessions connect to the commits and PRs they produced.</p>
      </div>

      <div class="headline-card">
        <div class="headline-metric">
          <div class="headline-val">{{headline.costPerMergedLine}}</div>
          <div class="headline-unit">cost per merged line</div>
        </div>
        <div class="headline-sep"></div>
        <div class="headline-copy">
          <strong>Cost-per-merged-line</strong>
          <p>Total AI session spend divided by lines of code that landed in merged PRs. Lower is more efficient. Reverted PRs are excluded from the denominator.</p>
        </div>
      </div>

      <div class="stats-row">
        <div class="stat-card" style="--card-accent: var(--orange)">
          <div class="stat-label">Total Sessions</div>
          <div class="stat-val" data-countup="{{headline.totalSessions}}" data-fmt="int">{{headline.totalSessions}}</div>
          <div class="stat-sub">ingested sessions</div>
        </div>
        <div class="stat-card" style="--card-accent: var(--gray-300)">
          <div class="stat-label">Total Spend</div>
          <div class="stat-val">{{headline.totalCost}}</div>
          <div class="stat-sub">across all sessions</div>
        </div>
        <div class="stat-card" style="--card-accent: var(--green)">
          <div class="stat-label">Merged PRs</div>
          <div class="stat-val" style="color:var(--green)" data-countup="{{headline.mergedPrs}}" data-fmt="int">{{headline.mergedPrs}}</div>
          <div class="stat-sub">PRs that landed</div>
        </div>
        <div class="stat-card" style="--card-accent: var(--red)">
          <div class="stat-label">Reverted PRs</div>
          <div class="stat-val" style="color:var(--red)" data-countup="{{headline.revertedPrs}}" data-fmt="int">{{headline.revertedPrs}}</div>
          <div class="stat-sub">PRs rolled back</div>
        </div>
      </div>

      {{#if chart.bars}}
      <div class="chart-card">
        <div class="chart-head">
          <div class="chart-title">Cost per session</div>
          <div class="chart-desc">Relative API spend per ingested session</div>
        </div>
        <div class="chart-svg-wrap">
          <svg width="100%" height="110" viewBox="0 0 {{chart.width}} 110" preserveAspectRatio="none">
            <defs>
              <linearGradient id="bar-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#E8623A" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="#C9502D" stop-opacity="0.7"/>
              </linearGradient>
            </defs>
            {{#each chart.bars}}
            <rect x="{{this.x}}" y="{{this.y}}" width="{{this.w}}" height="{{this.h}}" rx="3" fill="url(#bar-grad)"/>
            {{/each}}
          </svg>
        </div>
      </div>
      {{/if}}
    </div>
  </div>

  <!-- ─── Sessions ─── -->
  <div id="sec-sessions" class="section">
    <div class="topbar">
      <span class="topbar-title">Sessions</span>
    </div>
    <div class="page-body">
      <div class="page-header">
        <h1>Sessions</h1>
        <p class="page-subtitle">All ingested Claude Code sessions with commit and PR attribution.</p>
      </div>

      {{#if sessions}}
      <div class="section-head">
        <span class="section-head-title">All sessions</span>
        <span class="count-chip">{{headline.totalSessions}}</span>
      </div>

      <div class="table-card">
        <div class="table-head">
          <span class="th">Date</span>
          <span class="th">Project</span>
          <span class="th r">Prompts</span>
          <span class="th r">Tools</span>
          <span class="th r">Retries</span>
          <span class="th r">Cost</span>
          <span class="th"></span>
          <span class="th">Outcome</span>
        </div>

        {{#each sessions}}
        <details class="srow">
          <summary class="srow-sum">
            <span class="c-date">{{this.started_at_fmt}}</span>
            <span class="c-proj">{{this.project}}</span>
            <span class="c-num">{{this.prompt_count}}</span>
            <span class="c-num">{{this.tool_call_count}}</span>
            <span class="c-num">{{this.retry_count}}</span>
            <span class="c-cost">{{this.cost_fmt}}</span>
            <div class="bar-wrap">
              <div class="bar-bg"><div class="bar-fill" style="width:{{this.cost_pct}}%"></div></div>
            </div>
            <span>
              {{#if this.abandoned}}
                <span class="badge b-abandon">Abandoned</span>
              {{else if this.outcome_reverted}}
                <span class="badge b-reverted">Reverted</span>
              {{else if this.outcome_merged}}
                <span class="badge b-merged">Merged</span>
              {{else if this.outcome_open}}
                <span class="badge b-open">Open PR</span>
              {{else}}
                <span class="badge b-nopr">No PR</span>
              {{/if}}
            </span>
          </summary>

          <div class="srow-detail">
            <div class="detail-meta-row">
              <div class="dmeta"><strong>Session ID</strong>{{this.id}}</div>
              <div class="dmeta"><strong>Duration</strong>{{this.duration}}</div>
              <div class="dmeta"><strong>Directory</strong>{{this.cwd}}</div>
            </div>

            {{#if this.commits}}
            <div class="commits-label">Commits ({{this.commits.length}})</div>
            <table class="ctable">
              <thead>
                <tr>
                  <th>SHA</th><th>Authored</th><th>+Lines</th><th>−Lines</th><th>PR</th><th>State</th>
                </tr>
              </thead>
              <tbody>
                {{#each this.commits}}
                <tr>
                  <td><span class="sha-chip">{{this.sha_short}}</span></td>
                  <td style="color:var(--gray-500)">{{this.authored_fmt}}</td>
                  <td><span class="la">+{{this.added_lines}}</span></td>
                  <td><span class="ld">−{{this.deleted_lines}}</span></td>
                  <td>
                    {{#if this.pr_url}}
                      <a class="pr-a" href="{{this.pr_url}}" target="_blank">#{{this.pr_number}}</a>
                    {{else}}
                      <span style="color:var(--gray-300)">—</span>
                    {{/if}}
                  </td>
                  <td>
                    {{#if this.reverted}}
                      <span class="badge b-reverted">Reverted</span>
                    {{else if this.pr_state}}
                      {{#if (eq this.pr_state "MERGED")}}
                        <span class="badge b-merged">Merged</span>
                      {{else if (eq this.pr_state "OPEN")}}
                        <span class="badge b-open">Open</span>
                      {{else}}
                        <span class="badge b-nopr">{{this.pr_state}}</span>
                      {{/if}}
                    {{else}}
                      <span style="color:var(--gray-300)">—</span>
                    {{/if}}
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
            {{else}}
            <p style="color:var(--gray-400);font-size:12px;">No commits linked to this session.</p>
            {{/if}}
          </div>
        </details>
        {{/each}}
      </div>

      {{else}}
      <div class="empty-state">
        <div class="empty-icon">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
        </div>
        No sessions found. Run <code style="background:var(--gray-100);padding:2px 6px;border-radius:4px;font-family:monospace;font-size:12px">agent-trail ingest</code> to populate the database.
      </div>
      {{/if}}
    </div>
  </div>

  <!-- ─── AI Usage ─── -->
  <div id="sec-ai" class="section">
    <div class="topbar">
      <span class="topbar-title">AI Usage</span>
      <div class="topbar-right"><span class="beta-tag">Beta</span></div>
    </div>
    <div class="page-body">
      <div class="page-header">
        <h1>AI Usage</h1>
        <p class="page-subtitle">See how Claude Code sessions translate into shipped code.</p>
      </div>

      <div class="stats-row">
        <div class="stat-card" style="--card-accent:var(--orange); grid-column: span 2">
          <div class="stat-label">Cost Efficiency</div>
          <div class="stat-val" style="color:var(--orange)">{{headline.costPerMergedLine}}</div>
          <div class="stat-sub">per merged line — total spend ÷ merged lines (reverts excluded)</div>
        </div>
        <div class="stat-card" style="--card-accent:var(--gray-300)">
          <div class="stat-label">Sessions</div>
          <div class="stat-val" data-countup="{{headline.totalSessions}}" data-fmt="int">{{headline.totalSessions}}</div>
          <div class="stat-sub">ingested</div>
        </div>
        <div class="stat-card" style="--card-accent:var(--gray-300)">
          <div class="stat-label">Total Spend</div>
          <div class="stat-val">{{headline.totalCost}}</div>
          <div class="stat-sub">USD</div>
        </div>
      </div>

      {{#if chart.bars}}
      <div class="chart-card">
        <div class="chart-head">
          <div class="chart-title">Cost per session over time</div>
          <div class="chart-desc">Relative AI session spend across all ingested sessions</div>
        </div>
        <div class="chart-svg-wrap">
          <svg width="100%" height="140" viewBox="0 0 {{chart.width}} 140" preserveAspectRatio="none">
            <defs>
              <linearGradient id="bar-grad2" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#E8623A" stop-opacity="0.85"/>
                <stop offset="100%" stop-color="#C9502D" stop-opacity="0.6"/>
              </linearGradient>
            </defs>
            {{#each chart.bars}}
            <rect x="{{this.x}}" y="{{this.y}}" width="{{this.w}}" height="{{this.h}}" rx="3" fill="url(#bar-grad2)"/>
            {{/each}}
          </svg>
        </div>
      </div>
      {{/if}}
    </div>
  </div>

</main>

<script>
(function () {
  // ── Navigation ──
  var links = document.querySelectorAll('.nav-link[data-nav]');
  links.forEach(function (link) {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      var target = this.getAttribute('data-nav');

      links.forEach(function (l) { l.classList.remove('active'); });
      this.classList.add('active');

      document.querySelectorAll('.section').forEach(function (s) { s.classList.remove('active'); });
      var sec = document.getElementById('sec-' + target);
      if (sec) {
        sec.classList.add('active');
        runCountUps(sec);
      }
    });
  });

  // ── Count-up ──
  function easeOutExpo(t) {
    return t >= 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  function runCountUps(container) {
    container.querySelectorAll('[data-countup]').forEach(function (el) {
      if (el.dataset.done) return;
      el.dataset.done = '1';

      var end = parseFloat(el.getAttribute('data-countup'));
      if (isNaN(end)) return;

      var fmt = el.getAttribute('data-fmt');
      var startTime = null;
      var duration = 1100;

      function step(ts) {
        if (!startTime) startTime = ts;
        var progress = Math.min((ts - startTime) / duration, 1);
        var eased = easeOutExpo(progress);
        var current = end * eased;

        if (fmt === 'int') {
          el.textContent = Math.round(current).toString();
        }

        if (progress < 1) {
          requestAnimationFrame(step);
        } else {
          el.textContent = fmt === 'int' ? Math.round(end).toString() : el.getAttribute('data-countup');
        }
      }

      requestAnimationFrame(step);
    });
  }

  // Trigger on load for the visible section
  window.addEventListener('load', function () {
    setTimeout(function () {
      var active = document.querySelector('.section.active');
      if (active) runCountUps(active);
    }, 150);
  });
})();
</script>
</body>
</html>
