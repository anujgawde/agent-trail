<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>agent-trail</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --orange:     #E8623A;
  --orange-dk:  #C9502D;
  --orange-lt:  #FEF3EE;
  --green:      #16A34A;
  --green-lt:   #F0FDF4;
  --red:        #DC2626;
  --red-lt:     #FEF2F2;
  --blue:       #2563EB;
  --sidebar-w:  228px;
  --gray-50:    #F9FAFB;
  --gray-100:   #F3F4F6;
  --gray-150:   #EDEFF2;
  --gray-200:   #E5E7EB;
  --gray-300:   #D1D5DB;
  --gray-400:   #9CA3AF;
  --gray-500:   #6B7280;
  --gray-600:   #4B5563;
  --gray-700:   #374151;
  --gray-800:   #1F2937;
  --gray-900:   #111827;
  --radius:     10px;
  --shadow-sm:  0 1px 3px rgba(0,0,0,0.05), 0 1px 2px rgba(0,0,0,0.04);
}

html, body { height: 100%; }

body {
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--gray-50);
  color: var(--gray-900);
  font-size: 14px;
  line-height: 1.5;
  display: flex;
}

/* ── Sidebar ── */
.sidebar {
  width: var(--sidebar-w);
  min-height: 100vh;
  background: #fff;
  border-right: 1px solid var(--gray-200);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0; left: 0;
  z-index: 20;
  padding-bottom: 20px;
}

.sidebar-brand {
  padding: 14px 16px 12px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid var(--gray-100);
  margin-bottom: 6px;
}

.brand-logo {
  width: 34px; height: 34px;
  background: var(--orange);
  border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  color: #fff;
  font-weight: 800;
  font-size: 13px;
  letter-spacing: -0.3px;
  flex-shrink: 0;
}

.brand-name {
  font-weight: 700;
  font-size: 14px;
  color: var(--gray-900);
  letter-spacing: -0.2px;
}

.nav-group { padding: 4px 8px 2px; }

.nav-group-label {
  font-size: 10.5px;
  font-weight: 700;
  color: var(--gray-400);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  padding: 8px 8px 5px;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 10px;
  border-radius: 7px;
  cursor: pointer;
  color: var(--gray-600);
  font-size: 13px;
  font-weight: 500;
  transition: background 0.12s, color 0.12s;
  user-select: none;
  text-decoration: none;
  margin-bottom: 1px;
}

.nav-link:hover { background: var(--gray-100); color: var(--gray-900); }

.nav-link.active {
  background: var(--orange-lt);
  color: var(--orange);
  font-weight: 600;
}

.nav-icon {
  width: 15px; height: 15px;
  flex-shrink: 0;
  stroke: currentColor;
  fill: none;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.nav-badge {
  margin-left: auto;
  background: var(--orange);
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.sidebar-footer {
  margin-top: auto;
  padding: 12px 18px 0;
  border-top: 1px solid var(--gray-100);
  font-size: 11px;
  color: var(--gray-400);
  line-height: 1.6;
}

/* ── Main ── */
.main {
  margin-left: var(--sidebar-w);
  flex: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── Topbar ── */
.topbar {
  background: #fff;
  border-bottom: 1px solid var(--gray-200);
  padding: 0 32px;
  height: 52px;
  display: flex;
  align-items: center;
  gap: 12px;
  position: sticky;
  top: 0;
  z-index: 10;
}

.topbar-title {
  font-weight: 700;
  font-size: 15px;
  color: var(--gray-900);
}

.topbar-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }

.filter-chip {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 5px 10px;
  border: 1px solid var(--gray-200);
  border-radius: 6px;
  font-size: 12px;
  color: var(--gray-600);
  background: #fff;
  cursor: default;
}

.filter-chip svg {
  width: 12px; height: 12px;
  stroke: var(--gray-400);
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.beta-tag {
  font-size: 10px;
  font-weight: 700;
  background: var(--orange);
  color: #fff;
  padding: 3px 7px;
  border-radius: 5px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* ── Back button ── */
.back-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--gray-500);
  font-size: 13px;
  font-weight: 500;
  padding: 5px 10px;
  border-radius: 7px;
  font-family: inherit;
  transition: background 0.12s, color 0.12s;
}
.back-btn:hover { background: var(--gray-100); color: var(--gray-900); }
.back-btn svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

.topbar-sep { color: var(--gray-300); font-size: 16px; }
.topbar-crumb { font-size: 13px; color: var(--gray-400); font-weight: 500; }

/* ── Sections ── */
.section { display: none; }
.section.active { display: flex; flex-direction: column; flex: 1; }

.page-body { padding: 28px 32px 64px; }

.page-header { margin-bottom: 22px; }
.page-header h1 { font-size: 20px; font-weight: 700; color: var(--gray-900); letter-spacing: -0.3px; }
.page-subtitle { font-size: 13px; color: var(--gray-500); margin-top: 3px; }

/* ── Headline card ── */
.headline-card {
  background: #fff;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  padding: 22px 28px;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 28px;
  box-shadow: var(--shadow-sm);
}

.headline-metric { flex-shrink: 0; }

.headline-val {
  font-size: 46px;
  font-weight: 800;
  color: var(--orange);
  line-height: 1;
  letter-spacing: -2px;
  font-variant-numeric: tabular-nums;
}

.headline-unit {
  font-size: 12px;
  color: var(--gray-400);
  font-weight: 500;
  margin-top: 5px;
}

.headline-sep {
  width: 1px;
  height: 56px;
  background: var(--gray-200);
  flex-shrink: 0;
}

.headline-copy strong {
  display: block;
  font-size: 13.5px;
  font-weight: 700;
  color: var(--gray-800);
  margin-bottom: 4px;
}

.headline-copy p {
  font-size: 12.5px;
  color: var(--gray-500);
  max-width: 360px;
  line-height: 1.65;
}

/* ── Stat cards ── */
.stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  margin-bottom: 20px;
}

.stat-card {
  background: #fff;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  padding: 18px 20px 16px;
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
  cursor: default;
}

.stat-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2.5px;
  background: var(--card-accent, transparent);
  border-radius: 0 0 var(--radius) var(--radius);
  opacity: 0;
  transition: opacity 0.2s;
}

.stat-card:hover::after { opacity: 1; }

.stat-label {
  font-size: 11px;
  font-weight: 700;
  color: var(--gray-400);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  margin-bottom: 8px;
}

.stat-val {
  font-size: 30px;
  font-weight: 800;
  color: var(--gray-900);
  line-height: 1;
  letter-spacing: -1px;
  font-variant-numeric: tabular-nums;
}

.stat-sub {
  font-size: 11.5px;
  color: var(--gray-400);
  margin-top: 5px;
}

/* ── Chart card ── */
.chart-card {
  background: #fff;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  padding: 20px 24px;
  margin-bottom: 20px;
  box-shadow: var(--shadow-sm);
}

.chart-head {
  margin-bottom: 16px;
}

.chart-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--gray-800);
}

.chart-desc {
  font-size: 12px;
  color: var(--gray-400);
  margin-top: 2px;
}

.chart-svg-wrap { overflow: hidden; border-radius: 6px; background: var(--gray-50); }
.chart-axis-label { font-size: 10px; font-weight: 700; color: var(--gray-400); text-transform: uppercase; letter-spacing: 0.06em; }

/* ── Directory grid ── */
.dir-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
  gap: 16px;
}

.dir-card {
  background: #fff;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  padding: 20px 22px 18px;
  cursor: pointer;
  transition: border-color 0.15s, box-shadow 0.15s, transform 0.12s;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: 0;
  user-select: none;
}

.dir-card:hover {
  border-color: var(--orange);
  box-shadow: 0 4px 16px rgba(232, 98, 58, 0.12);
  transform: translateY(-1px);
}

.dir-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 6px;
}

.dir-card-icon {
  width: 32px; height: 32px;
  background: var(--orange-lt);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  margin-bottom: 14px;
}

.dir-card-icon svg {
  width: 16px; height: 16px;
  stroke: var(--orange);
  fill: none;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.dir-card-name {
  font-size: 14px;
  font-weight: 700;
  color: var(--gray-900);
  margin-bottom: 3px;
  letter-spacing: -0.2px;
}

.dir-card-path {
  font-size: 10.5px;
  color: var(--gray-400);
  font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 18px;
}

.dir-card-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px 16px;
  padding-top: 14px;
  border-top: 1px solid var(--gray-100);
}

.dir-stat {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.dir-stat-val {
  font-size: 17px;
  font-weight: 800;
  color: var(--gray-900);
  letter-spacing: -0.5px;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}

.dir-stat-lbl {
  font-size: 10px;
  font-weight: 600;
  color: var(--gray-400);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.dir-card-arrow {
  width: 20px; height: 20px;
  stroke: var(--gray-300);
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  flex-shrink: 0;
  transition: stroke 0.15s;
}

.dir-card:hover .dir-card-arrow { stroke: var(--orange); }

/* ── Sessions section ── */
.section-head {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}

.section-head-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--gray-900);
}

.count-chip {
  font-size: 11.5px;
  font-weight: 600;
  color: var(--gray-500);
  background: var(--gray-100);
  padding: 2px 8px;
  border-radius: 99px;
}

/* ── Table ── */
.table-card {
  background: #fff;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.table-head {
  display: grid;
  grid-template-columns: 155px 1fr 68px 62px 62px 76px 96px 118px;
  gap: 12px;
  padding: 9px 20px;
  background: var(--gray-50);
  border-bottom: 1px solid var(--gray-200);
}

.th {
  font-size: 10.5px;
  font-weight: 700;
  color: var(--gray-400);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.th.r { text-align: right; }

details.srow { border-bottom: 1px solid var(--gray-100); }
details.srow:last-child { border-bottom: none; }
details.srow[open] { border-bottom-color: var(--gray-200); }

summary.srow-sum {
  display: grid;
  grid-template-columns: 155px 1fr 68px 62px 62px 76px 96px 118px;
  gap: 12px;
  padding: 11px 20px;
  cursor: pointer;
  list-style: none;
  user-select: none;
  align-items: center;
  transition: background 0.1s;
}

summary.srow-sum::-webkit-details-marker { display: none; }
summary.srow-sum:hover { background: var(--gray-50); }
details.srow[open] summary.srow-sum { background: var(--orange-lt); }

.c-date  { font-size: 12px; color: var(--gray-500); font-weight: 500; }
.c-proj  { font-size: 13px; font-weight: 600; color: var(--gray-900); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.c-num   { font-size: 12.5px; color: var(--gray-700); text-align: right; font-variant-numeric: tabular-nums; }
.c-cost  { font-size: 12.5px; font-weight: 700; color: var(--gray-900); text-align: right; font-variant-numeric: tabular-nums; }

.bar-wrap { display: flex; align-items: center; }
.bar-bg { flex: 1; height: 4px; background: var(--gray-150); border-radius: 99px; overflow: hidden; }
.bar-fill { height: 100%; background: var(--orange); border-radius: 99px; }

.badge {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 8px;
  border-radius: 6px;
  font-size: 10.5px; font-weight: 700;
  letter-spacing: 0.01em; white-space: nowrap;
}
.badge::before {
  content: '';
  width: 5px; height: 5px;
  border-radius: 50%; background: currentColor; flex-shrink: 0;
}

.b-merged   { background: var(--green-lt); color: var(--green); }
.b-reverted { background: var(--red-lt);   color: var(--red);   }
.b-open     { background: var(--orange-lt); color: var(--orange); }
.b-abandon  { background: var(--gray-100); color: var(--gray-500); }
.b-nopr     { background: var(--gray-100); color: var(--gray-400); }

/* ── Session detail ── */
.srow-detail {
  padding: 16px 20px 18px;
  background: var(--gray-50);
  border-top: 1px solid var(--gray-200);
}

.detail-meta-row {
  display: flex; gap: 28px; flex-wrap: wrap; margin-bottom: 14px;
}

.dmeta { font-size: 12px; color: var(--gray-500); }
.dmeta strong {
  display: block;
  font-size: 10.5px;
  font-weight: 700;
  color: var(--gray-400);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 2px;
}

.commits-label {
  font-size: 11px; font-weight: 700;
  color: var(--gray-500);
  text-transform: uppercase; letter-spacing: 0.06em;
  margin-bottom: 8px;
}

.ctable {
  width: 100%; border-collapse: collapse; font-size: 12px;
  background: #fff; border-radius: 8px; overflow: hidden;
  border: 1px solid var(--gray-200);
}

.ctable th {
  text-align: left; color: var(--gray-400); font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.04em;
  padding: 7px 12px; font-size: 10px;
  background: var(--gray-50); border-bottom: 1px solid var(--gray-200);
}

.ctable td { padding: 8px 12px; border-top: 1px solid var(--gray-100); }
.ctable tr:first-child td { border-top: none; }

.sha-chip {
  font-family: "SF Mono", "Fira Code", "Cascadia Code", ui-monospace, monospace;
  color: var(--blue); font-size: 11px;
  background: #EFF6FF; padding: 2px 6px; border-radius: 4px;
}

.la { color: var(--green); font-weight: 700; }
.ld { color: var(--red);   font-weight: 700; }
.pr-a { color: var(--orange); text-decoration: none; font-weight: 700; }
.pr-a:hover { text-decoration: underline; }

/* ── Empty ── */
.empty-state {
  text-align: center; padding: 56px 24px;
  color: var(--gray-400); font-size: 13px;
}

.empty-icon {
  width: 40px; height: 40px;
  background: var(--gray-100); border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 12px; color: var(--gray-300);
}

/* ── Scroll ── */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--gray-200); border-radius: 3px; }
</style>
</head>
<body>

<!-- ═══ Sidebar ═══ -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-logo">AT</div>
    <span class="brand-name">agent-trail</span>
  </div>

  <div class="nav-group">
    <div class="nav-group-label">Reports</div>
    <a class="nav-link active" data-nav="overview">
      <svg class="nav-icon" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Overview
    </a>
    <a class="nav-link" data-nav="sessions">
      <svg class="nav-icon" viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
      Directories
    </a>
  </div>

  <div class="nav-group">
    <div class="nav-group-label">Insights</div>
    <a class="nav-link" data-nav="ai">
      <svg class="nav-icon" viewBox="0 0 24 24"><path d="M12 2a5 5 0 015 5v1a5 5 0 01-10 0V7a5 5 0 015-5z"/><path d="M12 14c-5.33 0-8 2.67-8 4v2h16v-2c0-1.33-2.67-4-8-4z"/></svg>
      AI Usage
      <span class="nav-badge">Beta</span>
    </a>
  </div>

  <div class="sidebar-footer">
    Generated<br>{{generatedAt}}
  </div>
</aside>

<!-- ═══ Main ═══ -->
<main class="main">

  <!-- ─── Overview ─── -->
  <div id="sec-overview" class="section active">
    <div class="topbar">
      <span class="topbar-title">Overview</span>
    </div>
    <div class="page-body">
      <div class="page-header">
        <h1>Overview</h1>
        <p class="page-subtitle">A summary of all Claude Code sessions — spend, outcomes, and PR attribution across every directory.</p>
      </div>

      {{#if headline.costPerMergedLineAvailable}}
      <div class="headline-card">
        <div class="headline-metric">
          <div class="headline-val">{{headline.costPerMergedLine}}</div>
          <div class="headline-unit">cost per merged line</div>
        </div>
        <div class="headline-sep"></div>
        <div class="headline-copy">
          <strong>Your efficiency score</strong>
          <p>Total AI session spend ÷ lines of code that landed in a merged PR. A lower number means more shipped code per dollar. Reverted PRs are excluded.</p>
        </div>
      </div>
      {{/if}}

      <div class="stats-row">
        <div class="stat-card" style="--card-accent: var(--orange)">
          <div class="stat-label">Total Sessions</div>
          <div class="stat-val" data-countup="{{headline.totalSessions}}" data-fmt="int">{{headline.totalSessions}}</div>
          <div class="stat-sub">ingested Claude Code sessions</div>
        </div>
        <div class="stat-card" style="--card-accent: var(--gray-600)">
          <div class="stat-label">Total Spend</div>
          <div class="stat-val">{{headline.totalCost}}</div>
          <div class="stat-sub">API cost across all sessions</div>
        </div>
        <div class="stat-card" style="--card-accent: var(--green)">
          <div class="stat-label">Merged PRs</div>
          <div class="stat-val" style="color:var(--green)" data-countup="{{headline.mergedPrs}}" data-fmt="int">{{headline.mergedPrs}}</div>
          <div class="stat-sub">PRs attributed to sessions</div>
        </div>
        <div class="stat-card" style="--card-accent: var(--red)">
          <div class="stat-label">Reverted PRs</div>
          <div class="stat-val" style="color:var(--red)" data-countup="{{headline.revertedPrs}}" data-fmt="int">{{headline.revertedPrs}}</div>
          <div class="stat-sub">PRs that were rolled back</div>
        </div>
      </div>

      {{#if chart.bars}}
      <div class="chart-card">
        <div class="chart-head" style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px">
          <div>
            <div class="chart-title">API spend per session</div>
            <div class="chart-desc">Each bar is one session, ordered chronologically. Height = relative cost. Tallest bar = {{chart.maxCostFmt}}.</div>
          </div>
        </div>
        <div style="display:flex; gap:8px; margin-top:12px">
          <div style="width:32px; flex-shrink:0; display:flex; align-items:center; justify-content:center">
            <span class="chart-axis-label" style="writing-mode:vertical-rl; transform:rotate(180deg)">Spend</span>
          </div>
          <div style="flex:1; min-width:0">
            <div class="chart-svg-wrap">
              <svg width="100%" height="110" viewBox="0 0 {{chart.width}} 110" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="bar-grad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#E8623A" stop-opacity="0.9"/>
                    <stop offset="100%" stop-color="#C9502D" stop-opacity="0.7"/>
                  </linearGradient>
                </defs>
                <line x1="0" y1="25" x2="{{chart.width}}" y2="25" stroke="#E5E7EB" stroke-width="1"/>
                <line x1="0" y1="50" x2="{{chart.width}}" y2="50" stroke="#E5E7EB" stroke-width="1"/>
                <line x1="0" y1="75" x2="{{chart.width}}" y2="75" stroke="#E5E7EB" stroke-width="1"/>
                {{#each chart.bars}}
                <rect x="{{this.x}}" y="{{this.y}}" width="{{this.w}}" height="{{this.h}}" rx="2" fill="url(#bar-grad)" data-bar-cost="{{this.cost}}" data-bar-date="{{this.date}}"/>
                {{/each}}
              </svg>
            </div>
            <div style="margin-top:5px">
              <span class="chart-axis-label">Sessions (newest → oldest )</span>
            </div>
          </div>
        </div>
      </div>
      {{/if}}
    </div>
  </div>

  <!-- ─── Directory list ─── -->
  <div id="sec-sessions" class="section">
    <div class="topbar">
      <span class="topbar-title">Directories</span>
      <div class="topbar-right">
        <span class="count-chip">{{headline.directoryCount}} directories</span>
      </div>
    </div>
    <div class="page-body">
      <div class="page-header">
        <h1>Directories</h1>
        <p class="page-subtitle">Sessions grouped by working directory. Click a directory to see its sessions and detailed stats.</p>
      </div>

      {{#if directories}}
      <div class="dir-grid">
        {{#each directories}}
        <div class="dir-card" data-dir-nav="{{this.dirId}}">
          <div class="dir-card-icon">
            <svg viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
          </div>
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px">
            <div style="min-width:0;flex:1">
              <div class="dir-card-name">{{this.project}}</div>
              <div class="dir-card-path">{{this.cwd}}</div>
            </div>
            <svg class="dir-card-arrow" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
          <div class="dir-card-stats">
            <div class="dir-stat">
              <span class="dir-stat-val">{{this.sessionCount}}</span>
              <span class="dir-stat-lbl">Sessions</span>
            </div>
            <div class="dir-stat">
              <span class="dir-stat-val">{{this.totalCost}}</span>
              <span class="dir-stat-lbl">Spend</span>
            </div>
            <div class="dir-stat">
              <span class="dir-stat-val" style="color:var(--green)">{{this.mergedPrs}}</span>
              <span class="dir-stat-lbl">Merged</span>
            </div>
            <div class="dir-stat">
              <span class="dir-stat-val" style="color:var(--red)">{{this.revertedPrs}}</span>
              <span class="dir-stat-lbl">Reverted</span>
            </div>
          </div>
        </div>
        {{/each}}
      </div>

      {{else}}
      <div class="empty-state">
        <div class="empty-icon">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
        </div>
        No sessions found. Run <code style="background:var(--gray-100);padding:2px 6px;border-radius:4px;font-family:monospace;font-size:12px">agent-trail ingest</code> to populate the database.
      </div>
      {{/if}}
    </div>
  </div>

  <!-- ─── Directory detail pages (one per directory) ─── -->
  {{#each directories}}
  <div id="sec-{{this.dirId}}" class="section">
    <div class="topbar">
      <button class="back-btn" data-back-nav="sessions">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        Directories
      </button>
      <span class="topbar-sep">/</span>
      <span class="topbar-crumb">{{this.project}}</span>
    </div>
    <div class="page-body">
      <div class="page-header">
        <h1>{{this.project}}</h1>
        <p class="page-subtitle" style="font-family:monospace;font-size:12px">{{this.cwd}}</p>
      </div>

      <div class="stats-row">
        <div class="stat-card" style="--card-accent: var(--orange)">
          <div class="stat-label">Sessions</div>
          <div class="stat-val">{{this.sessionCount}}</div>
          <div class="stat-sub">in this directory</div>
        </div>
        <div class="stat-card" style="--card-accent: var(--gray-600)">
          <div class="stat-label">Total Spend</div>
          <div class="stat-val">{{this.totalCost}}</div>
          <div class="stat-sub">across sessions</div>
        </div>
        <div class="stat-card" style="--card-accent: var(--green)">
          <div class="stat-label">Merged PRs</div>
          <div class="stat-val" style="color:var(--green)">{{this.mergedPrs}}</div>
          <div class="stat-sub">PRs that landed</div>
        </div>
        <div class="stat-card" style="--card-accent: var(--red)">
          <div class="stat-label">Reverted PRs</div>
          <div class="stat-val" style="color:var(--red)">{{this.revertedPrs}}</div>
          <div class="stat-sub">PRs rolled back</div>
        </div>
      </div>

      {{#if this.chart.bars}}
      <div class="chart-card">
        <div class="chart-head" style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px">
          <div>
            <div class="chart-title">API spend per session</div>
            <div class="chart-desc">Each bar is one session in this directory, ordered chronologically. Tallest bar = {{this.chart.maxCostFmt}}.</div>
          </div>
        </div>
        <div style="display:flex; gap:8px; margin-top:12px">
          <div style="width:32px; flex-shrink:0; display:flex; align-items:center; justify-content:center">
            <span class="chart-axis-label" style="writing-mode:vertical-rl; transform:rotate(180deg)">Spend</span>
          </div>
          <div style="flex:1; min-width:0">
            <div class="chart-svg-wrap">
              <svg width="100%" height="110" viewBox="0 0 {{this.chart.width}} 110" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="bar-grad-{{this.dirId}}" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#E8623A" stop-opacity="0.9"/>
                    <stop offset="100%" stop-color="#C9502D" stop-opacity="0.7"/>
                  </linearGradient>
                </defs>
                <line x1="0" y1="25" x2="{{this.chart.width}}" y2="25" stroke="#E5E7EB" stroke-width="1"/>
                <line x1="0" y1="50" x2="{{this.chart.width}}" y2="50" stroke="#E5E7EB" stroke-width="1"/>
                <line x1="0" y1="75" x2="{{this.chart.width}}" y2="75" stroke="#E5E7EB" stroke-width="1"/>
                {{#each this.chart.bars}}
                <rect x="{{this.x}}" y="{{this.y}}" width="{{this.w}}" height="{{this.h}}" rx="2" fill="url(#bar-grad-{{../dirId}})" data-bar-cost="{{this.cost}}" data-bar-date="{{this.date}}"/>
                {{/each}}
              </svg>
            </div>
            <div style="margin-top:5px">
              <span class="chart-axis-label">Sessions (newest → oldest )</span>
            </div>
          </div>
        </div>
      </div>
      {{/if}}

      <div class="section-head">
        <span class="section-head-title">Sessions</span>
        <span class="count-chip">{{this.sessionCount}}</span>
      </div>

      <div class="table-card">
        <div class="table-head">
          <span class="th">Date</span>
          <span class="th">Project</span>
          <span class="th r">Prompts</span>
          <span class="th r">Tools</span>
          <span class="th r">Retries</span>
          <span class="th r">Cost</span>
          <span class="th"></span>
          <span class="th">Outcome</span>
        </div>

        {{#each this.sessions}}
        <details class="srow">
          <summary class="srow-sum">
            <span class="c-date">{{this.started_at_fmt}}</span>
            <span class="c-proj">{{this.project}}</span>
            <span class="c-num">{{this.prompt_count}}</span>
            <span class="c-num">{{this.tool_call_count}}</span>
            <span class="c-num">{{this.retry_count}}</span>
            <span class="c-cost">{{this.cost_fmt}}</span>
            <div class="bar-wrap">
              <div class="bar-bg"><div class="bar-fill" style="width:{{this.cost_pct}}%"></div></div>
            </div>
            <span>
              {{#if this.abandoned}}
                <span class="badge b-abandon">Abandoned</span>
              {{else if this.outcome_reverted}}
                <span class="badge b-reverted">Reverted</span>
              {{else if this.outcome_merged}}
                <span class="badge b-merged">Merged</span>
              {{else if this.outcome_open}}
                <span class="badge b-open">Open PR</span>
              {{else}}
                <span class="badge b-nopr">No PR</span>
              {{/if}}
            </span>
          </summary>

          <div class="srow-detail">
            <div class="detail-meta-row">
              <div class="dmeta"><strong>Session ID</strong>{{this.id}}</div>
              <div class="dmeta"><strong>Duration</strong>{{this.duration}}</div>
              <div class="dmeta"><strong>Directory</strong>{{this.cwd}}</div>
            </div>

            {{#if this.commits}}
            <div class="commits-label">Commits ({{this.commits.length}})</div>
            <table class="ctable">
              <thead>
                <tr>
                  <th>SHA</th><th>Authored</th><th>+Lines</th><th>−Lines</th><th>PR</th><th>State</th>
                </tr>
              </thead>
              <tbody>
                {{#each this.commits}}
                <tr>
                  <td><span class="sha-chip">{{this.sha_short}}</span></td>
                  <td style="color:var(--gray-500)">{{this.authored_fmt}}</td>
                  <td><span class="la">+{{this.added_lines}}</span></td>
                  <td><span class="ld">−{{this.deleted_lines}}</span></td>
                  <td>
                    {{#if this.pr_url}}
                      <a class="pr-a" href="{{this.pr_url}}" target="_blank">#{{this.pr_number}}</a>
                    {{else}}
                      <span style="color:var(--gray-300)">—</span>
                    {{/if}}
                  </td>
                  <td>
                    {{#if this.reverted}}
                      <span class="badge b-reverted">Reverted</span>
                    {{else if this.pr_state}}
                      {{#if (eq this.pr_state "MERGED")}}
                        <span class="badge b-merged">Merged</span>
                      {{else if (eq this.pr_state "OPEN")}}
                        <span class="badge b-open">Open</span>
                      {{else}}
                        <span class="badge b-nopr">{{this.pr_state}}</span>
                      {{/if}}
                    {{else}}
                      <span style="color:var(--gray-300)">—</span>
                    {{/if}}
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
            {{else}}
            <p style="color:var(--gray-400);font-size:12px;">No commits linked to this session.</p>
            {{/if}}
          </div>
        </details>
        {{/each}}
      </div>
    </div>
  </div>
  {{/each}}

  <!-- ─── AI Usage ─── -->
  <div id="sec-ai" class="section">
    <div class="topbar">
      <span class="topbar-title">AI Usage</span>
      <div class="topbar-right"><span class="beta-tag">Beta</span></div>
    </div>
    <div class="page-body">
      <div class="page-header">
        <h1>AI Usage</h1>
        <p class="page-subtitle">How Claude Code is being used — prompts, tool calls, and cost per session across all directories.</p>
      </div>

      <div class="stats-row">
        <div class="stat-card" style="--card-accent:var(--orange)">
          <div class="stat-label">Avg Cost / Session</div>
          <div class="stat-val" style="color:var(--orange)">{{headline.avgCostPerSession}}</div>
          <div class="stat-sub">mean API spend per session</div>
        </div>
        <div class="stat-card" style="--card-accent:var(--gray-600)">
          <div class="stat-label">Total Spend</div>
          <div class="stat-val">{{headline.totalCost}}</div>
          <div class="stat-sub">API cost across all sessions</div>
        </div>
        <div class="stat-card" style="--card-accent:var(--blue)">
          <div class="stat-label">Total Prompts</div>
          <div class="stat-val" style="color:var(--blue)" data-countup="{{headline.totalPrompts}}" data-fmt="int">{{headline.totalPrompts}}</div>
          <div class="stat-sub">user messages sent</div>
        </div>
        <div class="stat-card" style="--card-accent:var(--gray-600)">
          <div class="stat-label">Total Tool Calls</div>
          <div class="stat-val" data-countup="{{headline.totalToolCalls}}" data-fmt="int">{{headline.totalToolCalls}}</div>
          <div class="stat-sub">file edits, bash runs, reads</div>
        </div>
      </div>

      {{#if chart.bars}}
      <div class="chart-card">
        <div class="chart-head" style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px">
          <div>
            <div class="chart-title">API spend per session</div>
            <div class="chart-desc">Each bar is one session, ordered chronologically. Height = cost relative to the most expensive session ({{chart.maxCostFmt}}).</div>
          </div>
        </div>
        <div style="display:flex; gap:8px; margin-top:12px">
          <div style="width:32px; flex-shrink:0; display:flex; align-items:center; justify-content:center">
            <span class="chart-axis-label" style="writing-mode:vertical-rl; transform:rotate(180deg)">Spend</span>
          </div>
          <div style="flex:1; min-width:0">
            <div class="chart-svg-wrap">
              <svg width="100%" height="140" viewBox="0 0 {{chart.width}} 140" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="bar-grad2" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#E8623A" stop-opacity="0.85"/>
                    <stop offset="100%" stop-color="#C9502D" stop-opacity="0.6"/>
                  </linearGradient>
                </defs>
                <line x1="0" y1="35" x2="{{chart.width}}" y2="35" stroke="#E5E7EB" stroke-width="1"/>
                <line x1="0" y1="70" x2="{{chart.width}}" y2="70" stroke="#E5E7EB" stroke-width="1"/>
                <line x1="0" y1="105" x2="{{chart.width}}" y2="105" stroke="#E5E7EB" stroke-width="1"/>
                {{#each chart.bars}}
                <rect x="{{this.x}}" y="{{this.y}}" width="{{this.w}}" height="{{this.h}}" rx="2" fill="url(#bar-grad2)" data-bar-cost="{{this.cost}}" data-bar-date="{{this.date}}"/>
                {{/each}}
              </svg>
            </div>
            <div style="margin-top:5px">
              <span class="chart-axis-label">Sessions (newest → oldest )</span>
            </div>
          </div>
        </div>
      </div>
      {{/if}}
    </div>
  </div>

</main>

<!-- Bar tooltip (shared across all charts) -->
<div id="bar-tooltip" style="display:none; position:fixed; background:#111827; color:#fff; padding:7px 11px; border-radius:7px; font-size:12px; pointer-events:none; z-index:200; white-space:nowrap; box-shadow:0 4px 16px rgba(0,0,0,0.25)">
  <div id="bar-tooltip-cost" style="font-weight:700; font-variant-numeric:tabular-nums"></div>
  <div id="bar-tooltip-date" style="color:#9CA3AF; font-size:11px; margin-top:2px"></div>
</div>

<script>
(function () {
  // ── Navigation ──
  function navigate(target) {
    document.querySelectorAll('.section').forEach(function (s) { s.classList.remove('active'); });
    var sec = document.getElementById('sec-' + target);
    if (sec) {
      sec.classList.add('active');
      runCountUps(sec);
      window.scrollTo(0, 0);
    }

    var links = document.querySelectorAll('.nav-link[data-nav]');
    links.forEach(function (l) { l.classList.remove('active'); });
    var direct = document.querySelector('.nav-link[data-nav="' + target + '"]');
    if (direct) {
      direct.classList.add('active');
    } else {
      // For directory detail sections, keep the Directories nav link active
      var fallback = document.querySelector('.nav-link[data-nav="sessions"]');
      if (fallback) fallback.classList.add('active');
    }
  }

  // Sidebar nav clicks
  document.querySelectorAll('.nav-link[data-nav]').forEach(function (link) {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      navigate(this.getAttribute('data-nav'));
    });
  });

  // Directory card clicks
  document.querySelectorAll('[data-dir-nav]').forEach(function (card) {
    card.addEventListener('click', function () {
      navigate(this.getAttribute('data-dir-nav'));
    });
  });

  // Back button clicks
  document.querySelectorAll('[data-back-nav]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      navigate(this.getAttribute('data-back-nav'));
    });
  });

  // ── Count-up ──
  function easeOutExpo(t) {
    return t >= 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  function runCountUps(container) {
    container.querySelectorAll('[data-countup]').forEach(function (el) {
      if (el.dataset.done) return;
      el.dataset.done = '1';

      var end = parseFloat(el.getAttribute('data-countup'));
      if (isNaN(end)) return;

      var fmt = el.getAttribute('data-fmt');
      var startTime = null;
      var duration = 1100;

      function step(ts) {
        if (!startTime) startTime = ts;
        var progress = Math.min((ts - startTime) / duration, 1);
        var eased = easeOutExpo(progress);
        var current = end * eased;

        if (fmt === 'int') {
          el.textContent = Math.round(current).toString();
        }

        if (progress < 1) {
          requestAnimationFrame(step);
        } else {
          el.textContent = fmt === 'int' ? Math.round(end).toString() : el.getAttribute('data-countup');
        }
      }

      requestAnimationFrame(step);
    });
  }

  // ── Bar tooltips ──
  var tt = document.getElementById('bar-tooltip');
  var ttCost = document.getElementById('bar-tooltip-cost');
  var ttDate = document.getElementById('bar-tooltip-date');

  document.querySelectorAll('[data-bar-cost]').forEach(function (rect) {
    rect.style.cursor = 'crosshair';
    rect.addEventListener('mousemove', function (e) {
      ttCost.textContent = rect.getAttribute('data-bar-cost');
      ttDate.textContent = rect.getAttribute('data-bar-date');
      tt.style.display = 'block';
      tt.style.left = (e.clientX + 14) + 'px';
      tt.style.top = (e.clientY - 52) + 'px';
    });
    rect.addEventListener('mouseleave', function () {
      tt.style.display = 'none';
    });
  });

  // Trigger on load for the visible section
  window.addEventListener('load', function () {
    setTimeout(function () {
      var active = document.querySelector('.section.active');
      if (active) runCountUps(active);
    }, 150);
  });
})();
</script>
</body>
</html>
