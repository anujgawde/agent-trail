{
  "name": "agent-trail",
  "version": "0.1.0",
  "description": "Join AI coding agent sessions to git commits and PR outcomes",
  "type": "module",
  "bin": {
    "agent-trail": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "handlebars": "^4.7.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
